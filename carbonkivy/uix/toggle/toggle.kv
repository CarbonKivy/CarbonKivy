<CToggle>:
    canvas.after:
        Color:
            rgba: app.icon_on_color
        Ellipse:
            size: self.handle_size
            pos: self.handle_pos if self.handle_pos else (0, 0)
    size_hint: None, None
    size:
        { \
        "Large": [dp(48), dp(28)], \
        "Small": [dp(32), dp(18)], \
        }[self.role]
    handle_size:
        { \
        "Large": [dp(16), dp(16)], \
        "Small": [dp(10), dp(10)], \
        }[self.role]
    bg_color: 
        { \
        True: app.support_success, \
        False: app.toggle_off, \
        }[self.active]
    radius: self.height/2
    bg_color_focus: self.bg_color
    line_color_focus: app.focus
    inset_color_focus: app.focus_inset
    inset_width: dp(2)
    inset_color: app.transparent

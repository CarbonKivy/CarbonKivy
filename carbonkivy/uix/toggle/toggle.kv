<CToggle>:
    canvas.after:
        Color:
            rgba: app.icon_on_color
        SmoothEllipse:
            size: self.handle_size
            pos: self.handle_pos
        Color:
            rgba: app.support_success if self.active and self.role == "Small" else app.transparent 
        SmoothLine:
            width: dp(1.5)
            cap: 'round'
            joint: 'round'
            points:
                ( \
                self.handle_pos[0] + self.handle_size[0] * 0.28, self.handle_pos[1] + self.handle_size[1] * 0.50, \
                self.handle_pos[0] + self.handle_size[0] * 0.45, self.handle_pos[1] + self.handle_size[1] * 0.33, \
                self.handle_pos[0] + self.handle_size[0] * 0.72, self.handle_pos[1] + self.handle_size[1] * 0.65  \
                ) if self.handle_pos else []
    size_hint: None, None
    size:
        { \
        "Large": [dp(48), dp(28)], \
        "Small": [dp(34), dp(20)], \
        }[self.role]
    handle_size:
        { \
        "Large": [dp(18), dp(18)], \
        "Small": [dp(12), dp(12)], \
        }[self.role]
    bg_color: 
        { \
        True: app.support_success, \
        False: app.toggle_off, \
        }[self.active]
    radius: self.height/2
    bg_color_focus: self.bg_color
    line_color_focus: app.focus
    inset_color_focus: app.focus_inset
    inset_width: dp(2)
    inset_color: app.transparent
